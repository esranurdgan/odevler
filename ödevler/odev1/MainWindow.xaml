<Window x:Class="TetrisApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Neon Tetris OOP" Height="700" Width="500"
        Background="#121212" Foreground="White"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    
    <Window.Resources>
        <!-- Premium Glow Effect -->
        <Style x:Key="GlowBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#00F2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#1A0B2E" Offset="0"/>
                <GradientStop Color="#2E0B25" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Game Board -->
        <Border Grid.Column="0" Style="{StaticResource GlowBorder}" Padding="5" Width="312" HorizontalAlignment="Right">
            <Canvas x:Name="GameCanvas" Background="#0A0A0A" ClipToBounds="True" Width="300" Height="600"/>
        </Border>

        <!-- Info Panel -->
        <StackPanel Grid.Column="1" Margin="20,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="SIRADAKİ" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#00F2FF"/>
            <Border Style="{StaticResource GlowBorder}" Height="120" Width="120" HorizontalAlignment="Left" Padding="10">
                <Canvas x:Name="NextPieceCanvas" Background="#0A0A0A"/>
            </Border>

            <TextBlock Text="SKOR" FontSize="18" FontWeight="Bold" Margin="0,30,0,10" Foreground="#FF00E5"/>
            <TextBlock x:Name="ScoreText" Text="00000" FontSize="32" FontFamily="Consolas" Foreground="White"/>

            <Button Content="TEMAYI DEĞİŞTİR" Margin="0,30,0,0" Padding="10" 
                    Background="#AAFF00" Foreground="Black" FontWeight="Bold"
                    Click="ThemeButton_Click" Cursor="Hand"/>

            <Button Content="BAŞLAT" Margin="0,20,0,0" Padding="10" 
                    Background="#00F2FF" Foreground="Black" FontWeight="Bold"
                    Click="StartButton_Click" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <TextBlock x:Name="GameOverText" Text="OYUN BİTTİ" FontSize="24" FontWeight="Bold" 
                       Foreground="Red" Visibility="Collapsed" Margin="0,20,0,0" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
